{
  "compilerOptions": {
    "types": ["jest", "node"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "paths": {
      "@db/*": ["./src/infrastructure/database/*"],
      "@repo/*": ["./src/infrastructure/repository/*"],
      "@/*": ["./src/*"],
      "@domain/*": ["./src/domain/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@interfaces/*": ["./src/interfaces/*"],
      "@validation/*": ["./src/types/*"],
      "@use-cases/*": ["./src/use-cases//*"],
      "@vectorDB": ["./src/infrastructure/database/vectorDB/vectorDatabase.ts"]
    }
  },
  "include": [
    "./src/**/*",
    "jest-mongodb-config.ts",
    "../frontend/src/features/payment/components/CheckoutForm.tsx"
  ]
}
