{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strictNullChecks": true,
    "paths": {
      "@db/*": ["./src/database/*"],
      "@repo/*": ["./src/repository/*"],
      "@domain/*": ["./src/domain/*"]
    }
  },
  "include": ["./src/**/*"]
}
