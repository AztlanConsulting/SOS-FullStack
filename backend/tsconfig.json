{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strictNullChecks": true,
    "paths": {
      "@db/*": ["database/*"],
      "@repo/*": ["repository/*"],
      "@domain/*": ["domain/*"]
    }
  },
  "include": ["./src/**/*"]
}
