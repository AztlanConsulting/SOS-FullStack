{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strictNullChecks": true,
    "paths": {
      "@domain/*": ["./src/domain/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@interfaces/*": ["./src/interfaces/*"],
      "@types/*": ["./src/types/*"],
      "@vectorDB": ["./src/vectorDatabase.ts"]
    }
  },
  "include": ["./src/**/*"]
}
